{
    "name": "marque/bloodhound",
    "description": "BitTorrent tracker (announce/scrape) for Marque platform",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Letter Of Marque Software",
            "email": "dan@lom.software",
            "homepage": "https://lom.software"
        }
    ],
    "support": {
        "issues": "https://github.com/letterofmarque/marque/issues",
        "source": "https://github.com/letterofmarque/marque"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../trove",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../threepio",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": "^8.2",
        "marque/trove": "@dev",
        "marque/threepio": "@dev",
        "illuminate/support": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/redis": "^12.0",
        "illuminate/queue": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Marque\\Bloodhound\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marque\\Bloodhound\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Marque\\Bloodhound\\BloodhoundServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
